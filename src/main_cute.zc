    clear_screen();
    io.println("{}", COLOR_BOLD);
    io.println("╔══════════════════════════════════════════════════╗");
    io.println("║                🆘 游戏帮助                       ║");
    io.println("╚══════════════════════════════════════════════════╝");
    io.println("{}", COLOR_RESET);
    
    io.println("{}🎮 游戏目标:{}", COLOR_CYAN, COLOR_RESET);
    io.println("  控制小蛇 🐍 移动，吃到苹果 🍎 得分，避免撞到墙壁 🧱 或自己!");
    io.println();
    
    io.println("{}🎯 游戏规则:{}", COLOR_GREEN, COLOR_RESET);
    io.println("  1. 每吃一个苹果得10分");
    io.println("  2. 每得50分升一级，游戏速度加快");
    io.println("  3. 撞到墙壁或自己身体游戏结束");
    io.println("  4. 尽量创造最高分记录!");
    io.println();
    
    io.println("{}🎨 界面元素:{}", COLOR_YELLOW, COLOR_RESET);
    io.println("  🐍 - 蛇头 (你控制的部分)");
    io.println("  🟢 - 蛇身 (跟随蛇头移动)");
    io.println("  🍎 - 食物 (吃了会变长和得分)");
    io.println("  🧱 - 墙壁 (不能触碰)");
    io.println();
    
    io.println("{}🔄 游戏特性:{}", COLOR_MAGENTA, COLOR_RESET);
    io.println("  • 使用 Zen-C 现代系统编程语言开发");
    io.println("  • 真正的跨平台 (Windows/Linux/macOS)");
    io.println("  • 可爱的表情符号界面");
    io.println("  • 彩色终端支持");
    io.println("  • 分数和等级系统");
    io.println();
    
    io.println("{}💝 特别感谢:{}", COLOR_BLUE, COLOR_RESET);
    io.println("  感谢用户反馈让这个游戏变得更可爱、更美观!");
    io.println("  这个版本专门为喜欢可爱界面的玩家设计。");
    io.println();
    
    io.println("{}按任意键返回游戏...{}", COLOR_CYAN, COLOR_RESET);
}

// 主函数
fn main() -> i32 {
    // 设置控制台支持ANSI颜色
    #if IS_WINDOWS
        // Windows: 启用虚拟终端处理
        // system("chcp 65001 > nul");  // 设置UTF-8编码
    #endif
    
    io.println("{}", COLOR_BOLD);
    io.println("╔══════════════════════════════════════════════════╗");
    io.println("║      🎉 欢迎来到 Zen-C 贪吃蛇游戏 - 可爱版! 🎉   ║");
    io.println("╚══════════════════════════════════════════════════╝");
    io.println("{}", COLOR_RESET);
    
    io.println("{}✨ 特别版本说明:{}", COLOR_CYAN, COLOR_RESET);
    io.println("  这个版本专门为响应 GitHub Issue #1 而创建");
    io.println("  用户希望游戏界面更可爱、更美观、更专业");
    io.println("  我们使用了表情符号 🐍🍎🧱 和彩色界面!");
    io.println();
    
    io.println("{}🎮 游戏特点:{}", COLOR_GREEN, COLOR_RESET);
    io.println("  • 可爱的表情符号界面");
    io.println("  • 彩色终端支持");
    io.println("  • 专业的游戏信息面板");
    io.println("  • 分数和等级系统");
    io.println("  • 跨平台兼容性");
    io.println();
    
    io.println("{}🚀 技术栈:{}", COLOR_YELLOW, COLOR_RESET);
    io.println("  • 语言: Zen-C (现代系统编程语言)");
    io.println("  • 编译: 人类可读的 GNU C/C11");
    io.println("  • 平台: Windows, Linux, macOS");
    io.println("  • 特性: 类型安全、模式匹配、泛型、RAII");
    io.println();
    
    io.println("{}按任意键开始游戏...{}", COLOR_MAGENTA, COLOR_RESET);
    
    let mut game = GameState {
        snake: Snake {
            body: [Position { x: 0, y: 0 }; MAX_LENGTH],
            length: 0,
            direction: Direction::Right,
            color: COLOR_GREEN
        },
        food: Position { x: 0, y: 0 },
        score: 0,
        high_score: 0,
        game_over: false,
        paused: false,
        level: 1,
        speed: 200
    };
    
    init_game(&mut game);
    
    // 游戏主循环
    let mut running = true;
    let mut show_help_screen = false;
    
    while running {
        if show_help_screen {
            show_help();
            show_help_screen = false;
            // 等待按键
            continue;
        }
        
        draw_game(&game);
        
        // 注意：这是一个简化版本
        // 实际游戏需要非阻塞输入处理
        // 这里我们只更新游戏状态
        
        update_game(&mut game);
        time.sleep(game.speed as u64); // 使用动态速度
        
        // 简化：游戏运行30秒后自动结束演示
        // 在实际游戏中，这里应该有输入处理和游戏结束条件
        static mut counter: i32 = 0;
        unsafe {
            counter += 1;
            if counter > 150 { // 大约30秒
                game.game_over = true;
            }
        }
        
        if game.game_over {
            draw_game(&game);
            io.println("\n{}🎮 演示完成! 最终分数: {}{}", COLOR_BOLD, game.score, COLOR_RESET);
            io.println("{}✨ 这个版本展示了:{}", COLOR_CYAN, COLOR_RESET);
            io.println("  • 可爱的表情符号界面 🐍🍎🧱");
            io.println("  • 专业的游戏信息面板 📊");
            io.println("  • 跨平台兼容性 🌍");
            io.println("  • Zen-C 的现代特性 ⚡");
            io.println();
            io.println("{}💝 感谢您的反馈让游戏变得更美好!{}", COLOR_MAGENTA, COLOR_RESET);
            running = false;
        }
    }
    
    io.println("\n{}🐍 谢谢游玩 Zen-C 贪吃蛇游戏 - 可爱版!{}", COLOR_BOLD, COLOR_RESET);
    io.println("{}📢 如果您喜欢这个版本，请在 GitHub 上给我们一个星星! ⭐{}", COLOR_YELLOW, COLOR_RESET);
    io.println("{}🔗 GitHub: https://github.com/xingmu/zenc_snake_game{}", COLOR_BLUE, COLOR_RESET);
    
    0
}