// Zen-C Snake Game - 美观可爱版本 🐍✨
// 专门为用户反馈的界面美观需求设计
// 使用可爱的字符和专业的界面设计

import std.io;
import std.math;
import std.time;
import std.string;

// 平台检测
#if defined(_WIN32) || defined(WIN32) || defined(__WIN32__) || defined(__NT__)
    #define IS_WINDOWS 1
#else
    #define IS_WINDOWS 0
#endif

// 游戏常量 - 使用更合适的尺寸
const WIDTH: i32 = 25;
const HEIGHT: i32 = 15;
const MAX_LENGTH: i32 = 100;

// 可爱的字符集
const SNAKE_HEAD: string = "🐍";      // 蛇头 - 蛇表情
const SNAKE_BODY: string = "🟢";      // 蛇身 - 绿色圆圈
const FOOD: string = "🍎";            // 食物 - 苹果
const WALL: string = "🧱";            // 墙壁 - 砖块
const EMPTY: string = "  ";           // 空格 - 两个空格保持对齐

// 颜色代码 (ANSI转义序列)
const COLOR_RESET: string = "\x1b[0m";
const COLOR_GREEN: string = "\x1b[32m";
const COLOR_RED: string = "\x1b[31m";
const COLOR_YELLOW: string = "\x1b[33m";
const COLOR_BLUE: string = "\x1b[34m";
const COLOR_MAGENTA: string = "\x1b[35m";
const COLOR_CYAN: string = "\x1b[36m";
const COLOR_BOLD: string = "\x1b[1m";

// 方向枚举
enum Direction {
    Up,
    Down,
    Left,
    Right
}

// 位置结构
struct Position {
    x: i32,
    y: i32
}

// 蛇结构
struct Snake {
    body: [MAX_LENGTH]Position,
    length: i32,
    direction: Direction,
    color: string  // 蛇的颜色
}

// 游戏状态
struct GameState {
    snake: Snake,
    food: Position,
    score: i32,
    high_score: i32,
    game_over: bool,
    paused: bool,
    level: i32,
    speed: i32  // 游戏速度 (ms)
}

// 跨平台清屏函数
fn clear_screen() {
    #if IS_WINDOWS
        // Windows: 使用ANSI转义序列 (Windows 10+支持)
        io.print("\x1b[2J\x1b[H");
    #else
        // Unix/Linux/macOS: 使用ANSI转义序列
        io.print("\x1b[2J\x1b[H");
    #endif
}

// 设置控制台标题
fn set_title(title: string) {
    #if IS_WINDOWS
        io.print("\x1b]0;{}", title);
        io.print("\x07");
    #else
        io.print("\x1b]0;{}", title);
        io.print("\x07");
    #endif
}

// 绘制漂亮的边框
fn draw_border() {
    // 上边框
    io.print("┌");
    for _ in 0..(WIDTH * 2 + 2) {
        io.print("─");
    }
    io.println("┐");
    
    // 左右边框
    for _ in 0..HEIGHT {
        io.print("│ ");
        for _ in 0..WIDTH {
            io.print("  ");
        }
        io.println(" │");
    }
    
    // 下边框
    io.print("└");
    for _ in 0..(WIDTH * 2 + 2) {
        io.print("─");
    }
    io.println("┘");
}

// 在指定位置绘制字符
fn draw_at(x: i32, y: i32, ch: string) {
    // 移动到指定位置 (ANSI转义序列)
    io.print("\x1b[{};{}H", y + 3, x * 2 + 3);
    io.print("{}", ch);
}

// 初始化游戏
fn init_game(game: &mut GameState) {
    // 设置游戏标题
    set_title("🐍 Zen-C Snake Game - 可爱版");
    
    // 初始化蛇
    game.snake.length = 3;
    game.snake.direction = Direction::Right;
    game.snake.color = COLOR_GREEN;
    
    // 蛇的初始位置（水平线）
    for i in 0..game.snake.length {
        game.snake.body[i] = Position { x: 5 + i, y: 7 };
    }
    
    // 生成食物
    let seed = time.now().nanos();
    math.srand(seed);
    game.food = Position {
        x: math.rand() % (WIDTH - 2) + 1,
        y: math.rand() % (HEIGHT - 2) + 1
    };
    
    game.score = 0;
    game.high_score = 0;
    game.game_over = false;
    game.paused = false;
    game.level = 1;
    game.speed = 200;  // 初始速度 200ms
}

// 绘制游戏界面 - 美观可爱版本
fn draw_game(game: &GameState) {
    // 清屏
    clear_screen();
    
    // 绘制游戏标题
    io.println("{}", COLOR_BOLD);
    io.println("╔══════════════════════════════════════════════════╗");
    io.print("║  ");
    io.print("{}🐍 Zen-C Snake Game - 可爱版 🍎{}", COLOR_CYAN, COLOR_RESET);
    io.println("  ║");
    io.println("╚══════════════════════════════════════════════════╝");
    io.println("{}", COLOR_RESET);
    
    // 绘制游戏区域边框
    draw_border();
    
    // 绘制墙壁
    for x in 0..WIDTH {
        draw_at(x, 0, WALL);
        draw_at(x, HEIGHT - 1, WALL);
    }
    for y in 0..HEIGHT {
        draw_at(0, y, WALL);
        draw_at(WIDTH - 1, y, WALL);
    }
    
    // 绘制蛇
    for i in 0..game.snake.length {
        let pos = game.snake.body[i];
        if i == 0 {
            // 蛇头
            draw_at(pos.x, pos.y, SNAKE_HEAD);
        } else {
            // 蛇身
            draw_at(pos.x, pos.y, SNAKE_BODY);
        }
    }
    
    // 绘制食物
    draw_at(game.food.x, game.food.y, FOOD);
    
    // 移动光标到信息区域
    io.print("\x1b[{};1H", HEIGHT + 6);
    
    // 绘制信息面板
    io.println("{}", COLOR_BOLD);
    io.println("┌──────────────────────────────────────────────────┐");
    io.println("│                 📊 游戏信息                     │");
    io.println("├──────────────────────────────────────────────────┤");
    
    // 分数显示
    io.print("│  {}当前分数:{} ", COLOR_YELLOW, COLOR_RESET);
    io.print("{}{:4d}{}", COLOR_BOLD, game.score, COLOR_RESET);
    io.print("  │  {}最高分:{} ", COLOR_MAGENTA, COLOR_RESET);
    io.print("{}{:4d}{}", COLOR_BOLD, game.high_score, COLOR_RESET);
    io.println("  │");
    
    // 等级和速度
    io.print("│  {}当前等级:{} ", COLOR_GREEN, COLOR_RESET);
    io.print("{}{:2d}{}", COLOR_BOLD, game.level, COLOR_RESET);
    io.print("  │  {}游戏速度:{} ", COLOR_BLUE, COLOR_RESET);
    io.print("{}{:3d}ms{}", COLOR_BOLD, game.speed, COLOR_RESET);
    io.println("  │");
    
    io.println("├──────────────────────────────────────────────────┤");
    
    // 游戏状态
    if game.paused {
        io.println("│  {}⏸️  游戏已暂停 - 按 P 继续游戏{}          │", COLOR_YELLOW, COLOR_RESET);
    } else if game.game_over {
        io.println("│  {}💀 游戏结束! - 按 R 重新开始{}            │", COLOR_RED, COLOR_RESET);
    } else {
        io.println("│  {}▶️  游戏中... - 好好享受吧!{}              │", COLOR_GREEN, COLOR_RESET);
    }
    
    io.println("├──────────────────────────────────────────────────┤");
    
    // 控制说明
    io.println("│                 🎮 控制说明                     │");
    io.println("├──────────────────────────────────────────────────┤");
    io.println("│  W/↑    : 向上移动      A/← : 向左移动          │");
    io.println("│  S/↓    : 向下移动      D/→ : 向右移动          │");
    io.println("│  P      : 暂停/继续游戏   R : 重新开始游戏      │");
    io.println("│  Q      : 退出游戏       H : 显示帮助           │");
    io.println("└──────────────────────────────────────────────────┘");
    io.println("{}", COLOR_RESET);
    
    // 可爱的提示信息
    if game.score == 0 {
        io.println("{}💡 提示: 使用方向键或 WASD 控制小蛇移动，吃到苹果 🍎 得分!{}", COLOR_CYAN, COLOR_RESET);
    } else if game.score > 0 && game.score < 50 {
        io.println("{}🎉 加油! 你已经得到 {} 分了，继续努力!{}", COLOR_GREEN, game.score, COLOR_RESET);
    } else if game.score >= 50 && game.score < 100 {
        io.println("{}🌟 太棒了! {} 分! 你是个贪吃蛇高手!{}", COLOR_YELLOW, game.score, COLOR_RESET);
    } else if game.score >= 100 {
        io.println("{}🏆 传奇! {} 分! 你简直是个贪吃蛇大师!{}", COLOR_MAGENTA, game.score, COLOR_RESET);
    }
}

// 更新游戏状态
fn update_game(game: &mut GameState) {
    if game.game_over || game.paused {
        return;
    }
    
    // 移动蛇
    let mut new_head = game.snake.body[0];
    
    match game.snake.direction {
        Direction::Up => new_head.y -= 1,
        Direction::Down => new_head.y += 1,
        Direction::Left => new_head.x -= 1,
        Direction::Right => new_head.x += 1,
    }
    
    // 检查墙壁碰撞
    if new_head.x <= 0 || new_head.x >= WIDTH - 1 ||
       new_head.y <= 0 || new_head.y >= HEIGHT - 1 {
        game.game_over = true;
        return;
    }
    
    // 检查自身碰撞
    for i in 0..game.snake.length {
        if game.snake.body[i].x == new_head.x &&
           game.snake.body[i].y == new_head.y {
            game.game_over = true;
            return;
        }
    }
    
    // 移动蛇身
    for i in (1..game.snake.length).rev() {
        game.snake.body[i] = game.snake.body[i - 1];
    }
    game.snake.body[0] = new_head;
    
    // 检查是否吃到食物
    if new_head.x == game.food.x && new_head.y == game.food.y {
        // 增加蛇长
        if game.snake.length < MAX_LENGTH {
            game.snake.length += 1;
        }
        
        // 生成新食物
        game.food = Position {
            x: math.rand() % (WIDTH - 2) + 1,
            y: math.rand() % (HEIGHT - 2) + 1
        };
        
        // 增加分数
        game.score += 10;
        
        // 更新最高分
        if game.score > game.high_score {
            game.high_score = game.score;
        }
        
        // 每得50分升一级，加快速度
        if game.score % 50 == 0 {
            game.level += 1;
            if game.speed > 50 {  // 最低速度50ms
                game.speed -= 20;
            }
        }
    }
}

// 显示帮助信息
